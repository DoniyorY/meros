RewriteEngine On

RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

<IfModule mod_rewrite.c>
    Options +FollowSymlinks
    RewriteEngine On
    RewriteRule ^admin/(logo\.png|logo-white\.png)$ backend/web/$1 [L,NC]
    # Backend static files
    RewriteRule ^admin/(assets|css|js|images|fonts|libs)/(.*)$ backend/web/$1/$2 [L,NC]

    # Backend application
    RewriteCond %{REQUEST_URI} ^/admin(?:/|$)
    RewriteRule ^admin(?:/.*)?$ backend/web/index.php [L,QSA]

    # Frontend static files
    RewriteRule ^assets/(.*)$ frontend/web/assets/$1 [L,NC]
    RewriteRule ^css/(.*)$ frontend/web/css/$1 [L,NC]
    RewriteRule ^js/(.*)$ frontend/web/js/$1 [L,NC]
    RewriteRule ^images/(.*)$ frontend/web/images/$1 [L,NC]

    RewriteCond %{REQUEST_URI} !^/(frontend|backend)/web/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^.*$ frontend/web/index.php [L,QSA]
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “alt-php85” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-alt-php85___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
